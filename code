uart.c
#include "uart.h"

#define GPIOAEN (1U<<0)
#define USART2EN (1U<<17)

void UART2_Init(void)
{
    RCC->AHB1ENR |= GPIOAEN;
    RCC->APB1ENR |= USART2EN;

    /* PA2 TX , PA3 RX */
    GPIOA->MODER &= ~(0xF<<4);
    GPIOA->MODER |= (0xA<<4);

    GPIOA->AFR[0] |= (7<<8);
    GPIOA->AFR[0] |= (7<<12);

    USART2->BRR = 0x0683;

    USART2->CR1 |= (1<<3);
    USART2->CR1 |= (1<<2);
    USART2->CR1 |= (1<<13);
}

void UART2_SendChar(char c)
{
    while(!(USART2->SR & (1<<7)));
    USART2->DR = c;
}

void UART2_SendString(char *str)
{
    while(*str)
    {
        UART2_SendChar(*str++);
    }
}

/* ----------------- Added Function ----------------- */
char UART2_ReadChar(void)
{
    while(!(USART2->SR & (1<<5))); // Wait until RXNE (data received)
    return (char)USART2->DR;
}
