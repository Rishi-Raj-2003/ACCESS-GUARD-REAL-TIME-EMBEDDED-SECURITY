rtc.c
#include "rtc.h"

#define PWREN (1U<<28)
#define CR_DBP (1U<<8)

#define CSR_LSION (1U<<0)
#define CSR_LSIRDY (1U<<1)

#define BDCR_RTCEN (1U<<15)
#define BDCR_BDRST (1U<<16)

#define RTC_WRITE_PROTECTION_KEY1 0xCA
#define RTC_WRITE_PROTECTION_KEY2 0x53

#define RTC_ASYNCH_PREDIV 127
#define RTC_SYNCH_PREDIV 249

void rtc_init(void)
{

    RCC->APB1ENR |= PWREN;

    PWR->CR |= CR_DBP;

    RCC->CSR |= CSR_LSION;
    while(!(RCC->CSR & CSR_LSIRDY));

    RCC->BDCR |= BDCR_BDRST;
    RCC->BDCR &= ~BDCR_BDRST;

    RCC->BDCR |= (1<<9);
    RCC->BDCR |= BDCR_RTCEN;

    RTC->WPR = RTC_WRITE_PROTECTION_KEY1;
    RTC->WPR = RTC_WRITE_PROTECTION_KEY2;

    RTC->ISR |= (1<<7);
    while(!(RTC->ISR & (1<<6)));

    RTC->PRER = (RTC_ASYNCH_PREDIV<<16) | RTC_SYNCH_PREDIV;

    /* Set time 11:40:30 */
    RTC->TR = 0x112930;

    /* Set date 16-03-26 */
    RTC->DR = 0x260316;

    RTC->ISR &= ~(1<<7);

    RTC->WPR = 0xFF;
}

uint8_t rtc_convert_dec2bcd(uint8_t value)
{
    return (uint8_t)((value/10)<<4 | (value%10));
}

uint8_t rtc_convert_bcd2dec(uint8_t value)
{
    return (uint8_t)(((value>>4)*10)+(value & 0x0F));
}

uint32_t rtc_time_get_second(void)
{
    return (RTC->TR & 0x7F);
}

uint32_t rtc_time_get_minute(void)
{
    return ((RTC->TR >> 8) & 0x7F);
}

uint32_t rtc_time_get_hour(void)
{
    return ((RTC->TR >> 16) & 0x3F);
}

uint32_t rtc_date_get_day(void)
{
    return (RTC->DR & 0x3F);
}

uint32_t rtc_date_get_month(void)
{
    return ((RTC->DR >> 8) & 0x1F);
}

uint32_t rtc_date_get_year(void)
{
    return ((RTC->DR >> 16) & 0xFF);
}
