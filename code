#include "i2c.h"

#define GPIOBEN (1U<<1)
#define I2C1EN  (1U<<21)

void I2C1_Init(void)
{
    RCC->AHB1ENR |= GPIOBEN;
    RCC->APB1ENR |= I2C1EN;

    /* PB8 SCL , PB9 SDA */
    GPIOB->MODER &= ~(0xF<<16);
    GPIOB->MODER |=  (0xA<<16);

    GPIOB->OTYPER |= (3<<8);
    GPIOB->OSPEEDR |= (0xF<<16);
    GPIOB->PUPDR |= (0x5<<16);

    GPIOB->AFR[1] &= ~(0xFF);
    GPIOB->AFR[1] |= (4<<0);
    GPIOB->AFR[1] |= (4<<4);

    I2C1->CR1 = 0;
    I2C1->CR2 = 16;
    I2C1->CCR = 80;
    I2C1->TRISE = 17;

    I2C1->CR1 |= 1;
}

void I2C_Write(uint8_t addr,uint8_t control,uint8_t data)
{
    while(I2C1->SR2 & (1<<1));

    I2C1->CR1 |= (1<<8);

    while(!(I2C1->SR1 & 1));

    I2C1->DR = addr<<1;

    while(!(I2C1->SR1 & (1<<1)));

    volatile int temp = I2C1->SR2;

    I2C1->DR = control;

    while(!(I2C1->SR1 & (1<<7)));

    I2C1->DR = data;

    while(!(I2C1->SR1 & (1<<7)));

    I2C1->CR1 |= (1<<9);
}
