#include "stm32f4xx.h"
#include "i2c.h"
#include "oled.h"
#include "uart.h"
#include "rtc.h"
#include <string.h>
#include <stdio.h>

#define GPIOAEN (1U<<0)
#define GPIODEN (1U<<3)

#define GREEN_LED (1U<<12)
#define BUZ_PIN   (1U<<13)
#define RED_LED   (1U<<14)
#define BTN_PIN   (1U<<0)

char password[]="142003";

char input[7];
int pass_index=0;

uint8_t hour,min,sec;
uint8_t day,month,year;

char buffer[60];

/* delay functions */
void delay()
{
    for(int i=0;i<300000;i++);
}

void delay_1s()
{
    for(int i=0;i<5000000;i++);
}

/* CLEAR UART RX BUFFER */
void UART_ClearBuffer()
{
    while(USART2->SR & (1<<5))
    {
        volatile char dummy = USART2->DR;
    }
}

/* RESET PASSWORD */
void reset_password()
{
    memset(input,0,sizeof(input));
    pass_index=0;
}

/* PRINT RTC TIME */
void print_rtc_time()
{
    hour = rtc_convert_bcd2dec(rtc_time_get_hour());
    min  = rtc_convert_bcd2dec(rtc_time_get_minute());
    sec  = rtc_convert_bcd2dec(rtc_time_get_second());

    month = rtc_convert_bcd2dec(rtc_date_get_month());
    day   = rtc_convert_bcd2dec(rtc_date_get_day());
    year  = rtc_convert_bcd2dec(rtc_date_get_year());

    sprintf(buffer,
    "\r\nACCESS GRANTED\r\nTIME:%02d:%02d:%02d\r\nDATE:%02d-%02d-20%02d\r\n",
    hour,min,sec,day,month,year);

    UART2_SendString(buffer);
}

int main(void)
{

    RCC->AHB1ENR |= GPIOAEN | GPIODEN;

    /* BUTTON PA0 */
    GPIOA->MODER &= ~(3U<<0);
    GPIOA->PUPDR &= ~(3U<<0);
    GPIOA->PUPDR |= (2U<<0);

    /* GREEN LED PD12 */
    GPIOD->MODER |= (1<<24);
    GPIOD->MODER &= ~(1<<25);

    /* BUZZER PD13 */
    GPIOD->MODER |= (1<<26);
    GPIOD->MODER &= ~(1<<27);

    /* RED LED PD14 */
    GPIOD->MODER |= (1<<28);
    GPIOD->MODER &= ~(1<<29);

    I2C1_Init();
    OLED_Init();
    OLED_Clear();

    UART2_Init();
    rtc_init();

    OLED_SetCursor(0,0);
    OLED_String("ENTER PASSWORD");

    UART2_SendString("ENTER PASSWORD\r\n");

    UART_ClearBuffer();
    reset_password();

    while(1)
    {

        char c = UART2_ReadChar();
        UART2_SendChar(c);

        input[pass_index++] = c;

        if(pass_index==6)
        {

            input[6]='\0';

            /* CORRECT PASSWORD */
            if(strcmp(input,password)==0)
            {

                GPIOD->ODR |= BUZ_PIN;
                delay_1s();
                GPIOD->ODR &= ~BUZ_PIN;

                OLED_Clear();
                OLED_SetCursor(0,0);
                OLED_String("ACCESS GRANTED");

                delay();

                OLED_SetCursor(2,0);
                OLED_String("WELCOME");

                print_rtc_time();

                reset_password();

                /* WAIT FOR BUTTON */
                while(!(GPIOA->IDR & BTN_PIN));

                /* DOOR OPENING */

                GPIOD->ODR |= GREEN_LED;

                OLED_Clear();
                OLED_SetCursor(0,0);
                OLED_String("DOOR OPENING");

                UART2_SendString("\r\nDOOR OPENING\r\n");

                for(int j=0;j<5;j++)
                    delay_1s();

                /* DOOR CLOSING */

                GPIOD->ODR &= ~GREEN_LED;
                GPIOD->ODR |= RED_LED;

                OLED_Clear();
                OLED_SetCursor(0,0);
                OLED_String("DOOR CLOSING");

                UART2_SendString("DOOR CLOSING\r\n");

                for(int j=0;j<5;j++)
                    delay_1s();

                GPIOD->ODR &= ~RED_LED;

                /* RESET FOR NEXT USER */

                OLED_Clear();
                OLED_SetCursor(0,0);
                OLED_String("ENTER PASSWORD");

                UART2_SendString("\r\nENTER PASSWORD\r\n");

                UART_ClearBuffer();
                reset_password();
            }

            /* WRONG PASSWORD */

            else
            {

                GPIOD->ODR |= BUZ_PIN;
                GPIOD->ODR |= RED_LED;

                OLED_Clear();
                OLED_SetCursor(0,0);
                OLED_String("ACCESS DENIED");

                UART2_SendString("\r\nACCESS DENIED\r\n");

                delay_1s();

                GPIOD->ODR &= ~BUZ_PIN;
                GPIOD->ODR &= ~RED_LED;

                OLED_Clear();
                OLED_SetCursor(0,0);
                OLED_String("ENTER PASSWORD");

                UART2_SendString("ENTER PASSWORD\r\n");

                UART_ClearBuffer();
                reset_password();
            }
        }
    }
}
